[mysqld]
# ####################################################
# * Basic Settings
# ====================================================
user		= mysql
# 도커 환경에서는 아래 경로들이 이미 내부적으로 최적화되어 있으므로 
# 명시적으로 바꾸지 않는 한 주석 유지를 권장합니다.
# datadir	= /var/lib/mysql
# tmpdir	= /tmp

# MyISAM 설정
key_buffer_size		= 16M
myisam-recover-options  = BACKUP

# ###########################################################
# NFS 환경 설정
# ===========================================================
# NFS 환경에서 데이터 무결성과 성능을 위해 필수적인 설정
innodb_use_native_aio=0

# NFS의 파일 시스템 특성상 하위 디렉토리 생성/삭제 시 발생할 수 있는 문제 방지
innodb_flush_method=O_DIRECT

# ############################################################
# 로그 파일 기록과 관련된 설정 부
# ============================================================
# 에러 로그는 컨테이너 로그(docker logs)에서 확인하기 위해 
# 기본적으로 주석 처리하거나 경로를 확인하세요.
# log_error = /var/log/mysql/error.log

# 이진 로그 최대 크기
max_binlog_size   = 100M

# ############################################################
# [한글/시간 설정]
# ============================================================
# 서버 기본 문자셋을 utf8mb4로 설정 (이모지 지원 및 한글 최적화)
character-set-server = utf8mb4
collation-server     = utf8mb4_unicode_ci

# 클라이언트의 문자셋 설정을 무시하고 서버 설정을 강제 (인코딩 깨짐 방지)
skip-character-set-client-handshake

# [추가 추천] 접속하는 클라이언트들에게도 utf8mb4를 기본으로 알림
init_connect = "SET NAMES utf8mb4"

# 시간대 설정 (KST)
default-time-zone = '+09:00'

# ############################################################
# [Master 복제 설정]
# ============================================================
server_id=1                # 마스터 고유 ID
log-bin = mysql-bin          # 바이너리 로그 활성화 (이름만 지정하면 datadir에 생성됨)
binlog_format = ROW          # 행 기반 복제 (권장)
gtid_mode = ON               # GTID 사용

# 복제 시 안전하지 않은 작업은 시작하지 않게 함.
# 마스터와 슬레이브 간의 데이터가 꼬이는 것을 원천 봉쇄하여 데이터 정합성을 완벽하게 유지해 줍니다. 
# GTID 모드를 사용한다면 이 옵션은 선택이 아닌 필수(ON)입니다.
enforce_gtid_consistency = ON

# [NFS-1] 바이너리 로그 보존 기간 (8.0 기준, 단위: 초)
# 너무 짧으면 슬레이브가 동기화하기 전에 삭제되고, 너무 길면 NFS 용량을 압축합니다.
# 604800초 = 7일
binlog_expire_logs_seconds = 604800

# [NFS-2] 복제 정합성 보장 (NFS 환경 필수 권장)
# 트랜잭션이 발생할 때마다 바이너리 로그를 디스크에 동기화합니다.
sync_binlog = 1

# [NFS-3] 슬레이브에서 읽기 전용으로 마스터를 오인하는 것 방지
# (마스터에서는 굳이 필요 없으나 명시적으로 관리)
read_only = OFF

# [NFS-4] 바이너리 로그 체크섬
# 로그 파일 전송 중 오류가 발생하는지 검사합니다.
binlog_checksum = CRC32

# 접속하는 클라이언트의 IP를 보고 호스트네임(도메인)으로 바꾸는 과정을 생략하게 합니다.
# 외부 접속자의 호스트네임 확인 절차를 생략함으로 속 속도가 훨씬 빨라지고 외부 DNS 서버 장애에 영향을 받지 않습니다.
skip_name_resolve

# ############################################################
# [Client/Mysql 설정] - 클라이언트 툴 접속 시 한글 깨짐 방지
# ============================================================
[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4

